{
    "cli": {
        "--": {
            "pointer": "/nodes/quake/properties/startup commands"
        },
        "renderer": {
            "default": "pt",
            "type": "variant",
            "variants": {
                "mcpg": {
                    "merge": "renderers/mcpg.json",
                    "set": {
                        "/nodes/gbuffer/outputs": [
                            "emission->add.input_1",
                            "gbuffer->accumulate.gbuffer",
                            "gbuffer->accumulate.prev_gbuffer",
                            "gbuffer->render.gbuffer",
                            "gbuffer->svgf.gbuffer"
                        ],
                        "/nodes/render/properties/demodulate albedo": true,
                        "/nodes/render/properties/emission on primary": false,
                        "/nodes/render/properties/lc/LC min pdf": 10,
                        "/nodes/render/properties/max path length": 3
                    }
                },
                "pt": {
                    "merge": "renderers/pt.json",
                    "set": {
                        "/nodes/gbuffer/outputs": [
                            "emission->add.input_1",
                            "gbuffer->accumulate.gbuffer",
                            "gbuffer->accumulate.prev_gbuffer",
                            "gbuffer->render.gbuffer",
                            "gbuffer->svgf.gbuffer"
                        ],
                        "/nodes/render/properties/demodulate albedo": true,
                        "/nodes/render/properties/emission on primary": false,
                        "/nodes/render/properties/max path length": 3
                    }
                },
                "restir_di": {
                    "merge": "renderers/restir_di.json",
                    "set": {
                        "/nodes/gbuffer/outputs": [
                            "emission->add.input_1",
                            "gbuffer->accumulate.gbuffer",
                            "gbuffer->accumulate.prev_gbuffer",
                            "gbuffer->render.gbuffer",
                            "gbuffer->render.prev_gbuffer",
                            "gbuffer->svgf.gbuffer"
                        ],
                        "/nodes/render/properties/demodulate albedo": true,
                        "/nodes/render/properties/emission on primary": false
                    }
                }
            }
        }
    },
    "graph_properties": {
        "flush thread pool": true,
        "fps limiter": false,
        "imgui event": "ui",
        "iterations in flight": 2,
        "low latency": false,
        "time overwrite": "None"
    },
    "nodes": {
        "accumulate": {
            "enabled": true,
            "outputs": [
                "history->accumulate.prev_history",
                "history->svgf.history",
                "out->accumulate.prev_out",
                "out->svgf.src",
                "out->ui.extent_ref"
            ],
            "properties": {
                "IPR factor": 50.0,
                "adaptivity": 0.9009900093078613,
                "adaptivity IPR factor": 3.0,
                "adaptivity percentile lower": 0.1902180016040802,
                "adaptivity percentile upper": 0.9065219759941101,
                "alpha": 0.9509999752044678,
                "clear event pattern": "/user/clear",
                "depth threshold": 0.026403000578284264,
                "extended search": true,
                "filter mode": "stochastic bilinear",
                "firefly filter bias": 0.20000000298023224,
                "firefly filter enable": true,
                "firefly percentile lower": 0.25,
                "firefly percentile upper": 0.8999999761581421,
                "gbuffer check": "always",
                "hard clamp": "inf",
                "max history": "inf",
                "normal threshold": 0.645771861076355,
                "reuse border": true,
                "use motion vectors": true
            },
            "type": "Accumulate"
        },
        "add": {
            "enabled": true,
            "outputs": [
                "out->exposure.src"
            ],
            "properties": {
                "initial value": "",
                "number inputs": 2,
                "reduction": "accumulator + current_value"
            },
            "type": "Reduce"
        },
        "blit": {
            "enabled": true,
            "outputs": [
                "acquire->imgui.acquire"
            ],
            "properties": {
                "blit mode": "FIT",
                "source array element": 0
            },
            "type": "Swapchain Blit"
        },
        "composite": {
            "enabled": true,
            "outputs": [
                "out->blit.src"
            ],
            "properties": {
                "initial value": "",
                "number inputs": 2,
                "reduction": "current_value + float4(accumulator.rgb, 1) * (1.0 - current_value.a)"
            },
            "type": "Reduce"
        },
        "exposure": {
            "enabled": true,
            "outputs": [
                "out->tonemap.src"
            ],
            "properties": {
                "ISO": 856.0,
                "K": 8.0,
                "aperature": 1.1200000047683716,
                "autoexposure": true,
                "max exposure": 10000.0,
                "max log luminance": 12.0,
                "metering": "center-weighted",
                "min exposure": 1.0,
                "min log luminance": -15.0,
                "q": 0.6499999761581421,
                "shutter time (ms)": 768.0,
                "speed down": 5.099999904632568,
                "speed up": 3.0999999046325684
            },
            "type": "Exposure"
        },
        "fxaa": {
            "enabled": true,
            "outputs": [
                "out->composite.input_0"
            ],
            "type": "FXAA"
        },
        "gbuffer": {
            "enabled": true,
            "outputs": [
                "emission->add.input_1",
                "gbuffer->accumulate.gbuffer",
                "gbuffer->accumulate.prev_gbuffer",
                "gbuffer->render.gbuffer",
                "gbuffer->svgf.gbuffer"
            ],
            "properties": {
                "0": true,
                "1": true,
                "2": true,
                "3": true,
                "4": true,
                "5": true,
                "6": false,
                "7": true,
                "height": 1080,
                "width": 1920
            },
            "type": "GBuffer (Raytraced)"
        },
        "imgui": {
            "enabled": true,
            "properties": {
                "imgui event": "ui"
            },
            "type": "ImGui"
        },
        "output": {
            "enabled": true,
            "outputs": [
                "acquire->blit.acquire",
                "controller->quake.controller",
                "window->imgui.window",
                "window->quake.window"
            ],
            "properties": {
                "acquire timeout": 100000000,
                "backend": "SDL3 (Video Subsystem)",
                "blit mode": "FIT",
                "mode": "fullscreen",
                "on_should_close_actions": {
                    "remove node": false,
                    "send sigint": false,
                    "send sigterm": true
                },
                "present mode": "Mailbox",
                "rebuild on recreate": false,
                "surface format": "R8G8B8A8Srgb, SrgbNonlinear"
            },
            "type": "Window"
        },
        "quake": {
            "enabled": true,
            "outputs": [
                "scene->gbuffer.scene",
                "scene->render.scene",
                "scene->ui.scene",
                "ui_draw_commands->ui.ui_draw_commands"
            ],
            "properties": {
                "command": "",
                "env": {
                    "Pitch": 0.0,
                    "Type": "Empty",
                    "Yaw": 0.0
                },
                "filtering": "nearest",
                "gamestate update": true,
                "overwrite mu_t/s": false,
                "overwrite sun": false,
                "rebuild after stop": true,
                "reproducible renders": false,
                "settings": {
                    "Alpha Test Threshold": 0.699999988079071,
                    "BLAS Rebuild Fraction": 0.33000001311302185,
                    "Clamp Normals": true,
                    "Pretransform Animated": false
                },
                "startup commands": "",
                "stop after worldspawn": -1,
                "volume max t": 1000.0
            },
            "type": "Quake"
        },
        "svgf": {
            "enabled": true,
            "outputs": [
                "out->add.input_0",
                "out->svgf.prev_out"
            ],
            "properties": {
                "SVGF iterations": 5,
                "TAA alpha": 0.5,
                "clamping": "min-max",
                "debug": "none",
                "depth accept": 40.0,
                "enable motion vectors": true,
                "filter": "none",
                "filter depth": 40.0,
                "filter luminance": 3.0,
                "filter normals": 0.5235987901687622,
                "filter type": "subsampled",
                "kaleidoscope": false,
                "kaleidoscope: shmem": true,
                "mv sampling": "center",
                "normal reject": 0.5235987901687622,
                "spatial bias": 8.0,
                "spatial falloff": 3.0,
                "z-bias depth": 0.0,
                "z-bias normals": 3000.0
            },
            "type": "Denoiser (SVGF)"
        },
        "tonemap": {
            "enabled": true,
            "outputs": [
                "out->fxaa.src"
            ],
            "properties": {
                "alpha mode": "Perceptual luminance",
                "clamp output": true,
                "max white": 15.0,
                "perceptual exponent": 2.200000047683716,
                "tonemap": "Reinhard Extended"
            },
            "type": "Tonemap"
        },
        "ui": {
            "enabled": true,
            "outputs": [
                "out->composite.input_1"
            ],
            "type": "Quake UI"
        }
    },
    "version": 4
}
